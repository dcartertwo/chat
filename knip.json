{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "ignoreDependencies": [],
  "ignore": [],
  "rules": {
    "duplicates": "off"
  },
  "workspaces": {
    "examples/nitro-chat": {
      "entry": ["src/entry-client.tsx", "src/entry-server.tsx"],
      "nitro": {
        "entry": [
          "server.{js,mjs,ts}",
          "server/api/**/*.ts",
          "server/routes/**/*.ts",
          "server/middleware/**/*.ts",
          "server/plugins/**/*.ts",
          ".nitro/types/*.d.ts"
        ]
      }
    }
  }
}
